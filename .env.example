# Copy to .env (never commit .env) and fill in values.
# Locally: serve.mjs loads .env automatically via dotenv.
# On Vercel: set these in the project's Environment Variables dashboard.

# --- Step 2: Claude API ---
ANTHROPIC_API_KEY=

# --- Step 3+: Google (Gmail + Sheets) ---
# Generated by `python ../Ai\ quote\ bot/tools/google_oauth_bootstrap.py` (coming in step 3)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
LEADS_SHEET_ID=

# From/notify addresses
QUOTE_FROM_EMAIL=grimetoprime12@gmail.com
QUOTE_NOTIFY_EMAIL=grimetoprime12@gmail.com

# --- Step 5: Photos (Vercel Blob) ---
# Auto-provisioned by `vercel env pull` once you enable Blob Storage in the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=
